#include <iostream>
#include <windows.h>

#define window_char_size 100

void error()
{
	std::cout << "失败码->" << GetLastError() << std::endl;
	exit(-1);
}

int main()
{   
	/*SetConsoleCP(CP_UTF8);
	SetConsoleOutputCP(CP_UTF8);
	TCHAR window_mubaio[window_char_size];
#ifdef UNICODE
	wscanf_s(L"%s", window_mubaio,(unsigned)_countof(window_mubaio));
#else
	scanf_s("%s", window_mubaio, (unsigned)_countof(window_mubaio));
#endif*/
	//获得窗口句柄
	HWND hW = FindWindow(NULL, TEXT("植物大战僵尸中文版"));
	if (hW == NULL) { printf("找不到\n"); return 0; }
    
	//获得进程Pid
	DWORD dwPid = 0;
	if (!GetWindowThreadProcessId(hW, &dwPid)) { printf("打开进程失败\n"); return 0; }
	
	//获得进程句柄
	HANDLE hProcess = OpenProcess(PROCESS_ALL_ACCESS, FALSE, dwPid);
	if (hProcess == 0) { printf("获取句柄失败"); return 0; }
    
	//写入D:
	LPVOID lpBaseAddr = VirtualAllocEx(hProcess, NULL, 1024, MEM_COMMIT | MEM_RESERVE, PAGE_READWRITE);
	if (!lpBaseAddr) error();
		//D:
	LPCTSTR lpBuffer = TEXT("D:\\dll");//要注入的dll的位置
	WriteProcessMemory(hProcess, lpBaseAddr, lpBuffer, (lstrlen(lpBuffer) + 1) * sizeof(TCHAR),NULL);

	//找到LoadLibraryW()函数
	HMODULE hkernel32 = GetModuleHandle(TEXT("kernel32.dll"));//找kernel32.dll模块得基地址
	LPVOID pLoadLibrary = GetProcAddress(hkernel32,"LoadLibraryW");//找LoadLibrary地址
	if (!pLoadLibrary) error();
	
	//创建远程线程，并执行LoadLibrary()函数
	HANDLE hRmoteThread = CreateRemoteThread(hProcess, NULL, 0, (LPTHREAD_START_ROUTINE)pLoadLibrary, lpBaseAddr, 0, NULL);
	if (!hRmoteThread) error();

	//等待并关闭句柄
	WaitForSingleObject(hRmoteThread, INFINITE);
	DWORD exitCode = 0;
	GetExitCodeThread(hRmoteThread, &exitCode);
	printf("LoadLibrary返回值: 0x%p\n", exitCode);
	CloseHandle(hProcess);
	CloseHandle(hRmoteThread);
	return 0;
}
